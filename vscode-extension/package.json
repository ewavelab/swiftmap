{
  "name": "swiftmap",
  "displayName": "SwiftMap",
  "description": "Minimal mind map editor for Visual Studio Code.",
  "version": "1.0.2",
  "icon": "resources/icon.png",
  "publisher": "ewavelab",
  "license": "GPL-3.0-only",
  "categories": [
    "Visualization"
  ],
  "keywords": [
    "mind map",
    "outline",
    "tree",
    "diagram",
    "notes"
  ],
  "homepage": "https://swiftmap.pages.dev/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ewavelab/swiftmap.git"
  },
  "bugs": {
    "url": "https://github.com/ewavelab/swiftmap/issues"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "activationEvents": [
    "onLanguage:swiftmap",
    "onCustomEditor:swiftmap.editor"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "swiftmap",
        "aliases": [
          "SwiftMap",
          "swiftmap"
        ],
        "extensions": [
          ".swiftmap"
        ]
      }
    ],
    "customEditors": [
      {
        "viewType": "swiftmap.editor",
        "displayName": "SwiftMap Editor",
        "selector": [
          {
            "filenamePattern": "*.swiftmap"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "swiftmap.newDocument",
        "title": "SwiftMap: New Mind Map"
      },
      {
        "command": "swiftmap.openSource",
        "title": "SwiftMap: Open Source",
        "shortTitle": "Open Source",
        "icon": "$(go-to-file)"
      },
      {
        "command": "swiftmap.openVisualEditor",
        "title": "SwiftMap: Open Visual Editor",
        "shortTitle": "Open Visual Editor",
        "icon": "$(open-preview)"
      },
      {
        "command": "swiftmap.exportPng",
        "title": "SwiftMap: Export PNG",
        "shortTitle": "Export PNG",
        "icon": "$(link-external)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "swiftmap.openSource",
          "when": "activeCustomEditorId == swiftmap.editor",
          "group": "navigation"
        },
        {
          "command": "swiftmap.openVisualEditor",
          "when": "editorLangId == swiftmap && activeCustomEditorId != swiftmap.editor",
          "group": "navigation"
        },
        {
          "command": "swiftmap.exportPng",
          "when": "activeCustomEditorId == swiftmap.editor",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "build": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run build",
    "prepublishOnly": "npm run build",
    "package": "npx @vscode/vsce package --out ../swiftmap.vsix",
    "publish": "npx @vscode/vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.14.12",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.5.4"
  }
}
